[Unit]
Description=Al-Wilayat (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/al-wilayat/backend
# Clean KEY=value file (no inline comments). See deploy/al-wilayat.env.example
EnvironmentFile=/etc/al-wilayat.env
Environment=WILAYAT_NOBROWSER=1
ExecStart=/opt/al-wilayat/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
