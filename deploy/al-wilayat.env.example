# Copy to /etc/al-wilayat.env on the server and fill in real values.
# IMPORTANT: clean KEY=value lines only (systemd does not allow inline # comments).

# Long random string for signing login tokens.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
WILAYAT_SECRET=PUT_A_LONG_RANDOM_STRING_HERE

# Email (password-reset codes). Use a Gmail App Password, not your login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_FROM=youraddress@gmail.com
SMTP_PASS=your16charapppassword
